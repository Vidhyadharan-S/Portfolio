# .env.example
# Create a file named .env in the root directory and add your actual keys below.

# 1. Web3Forms Access Key
# Go to https://web3forms.com/ and click "Create your Access Key". 
# It is completely free and emails will be sent to the email address you provide.
VITE_CONTACT_FORM_KEY=your_web3forms_access_key_here

# 2. Gemini API Key
# Go to Google AI Studio (https://aistudio.google.com/app/apikey) to get a free API key.
VITE_GEMINI_API_KEY=your_gemini_api_key_here